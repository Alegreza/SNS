# =============================================================
# Kobe SNS — Environment Variables Checklist
# Copy this file to server/.env and fill in all required values.
# =============================================================

# ----- Server -----
PORT=3000

# ----- Database -----
# Render Postgres: copy "Internal Database URL" from the Render dashboard.
# Local dev: postgresql://user:password@localhost:5432/kobe
DATABASE_URL=

# ----- Auth: JWT -----
# Required. Use a long random string (e.g. openssl rand -hex 32).
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=30d

# ----- Auth: Google OAuth -----
# Get from: console.cloud.google.com → Credentials → OAuth 2.0 Client ID (Web)
# Must match googleClientId in src/auth-config.js
# Leave blank to disable Google login.
GOOGLE_CLIENT_ID=

# ----- Auth: Microsoft / Azure AD -----
# Get from: portal.azure.com → App registrations → Application (client) ID
# Used to validate azp/appid claim in JWKS token verification.
# Must match clientId in src/msal-config.js
# Leave blank to disable Microsoft login.
MICROSOFT_CLIENT_ID=

# ----- File Uploads -----
# Directory for student ID photo uploads (relative to server/).
UPLOAD_DIR=./data/uploads

# ----- Admin Account -----
# Default admin credentials (email: admin / password: admin) are seeded at startup.
# Change the password immediately after first login.
# A warning is printed to the console if the default password is still in use.
