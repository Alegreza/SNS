# Copy to .env and fill in values
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Supabase — Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# OAuth (leave blank to disable the respective provider)
# Google: console.cloud.google.com → Credentials → OAuth 2.0 Client ID (Web)
#   Must match googleClientId in src/auth-config.js
GOOGLE_CLIENT_ID=
# Microsoft: portal.azure.com → App registrations → Application (client) ID
#   Must match clientId in src/msal-config.js
#   Used to validate azp/appid claim in JWKS token verification
MICROSOFT_CLIENT_ID=

# Admin contact email shown to new users
ADMIN_EMAIL=mkim28@cranbrook.edu
